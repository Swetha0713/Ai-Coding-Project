PORT=3000

# -------------------------------------------------------
# MONGO_URI — choose ONE depending on how you run the app
# -------------------------------------------------------

# Option A: Running with Docker Compose (default)
MONGO_URI=mongodb://mongo:27017/alertcart

# Option B: Running locally WITHOUT Docker (comment out Option A and uncomment below)
# MONGO_URI=mongodb://localhost:27017/alertcart

# -------------------------------------------------------
# Email Config — Gmail App Password
# How to get App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → Create one for "Mail"
#   4. Paste the 16-character password below
# -------------------------------------------------------
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=AlertCart <your_email@gmail.com>

# Price check interval (every 6 hours by default)
# Format: minute hour day month weekday
CRON_SCHEDULE=0 */6 * * *
